{
  "info": {
    "_postman_id": "f8e65fb4-8f13-4fcb-a6c5-59a2b2924ff2",
    "name": "Microservices DevOps Project API Tests",
    "description": "Ready-to-run Postman requests for the local microservices DevOps project. Beginners should run one request at a time before running full folders.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 Direct Local Services",
      "item": [
        {
          "name": "Auth Health",
          "request": {
            "method": "GET",
            "url": "{{authBaseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('service is auth-service', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.service).to.eql('auth-service');",
                  "  pm.expect(json.status).to.eql('OK');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{userName}}\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": "{{authBaseUrl}}/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201 or user already exists', function () {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.environment.set('userId', String(json.id));",
                  "  pm.test('registered email matches environment', function () {",
                  "    pm.expect(json.email).to.eql(pm.environment.get('userEmail'));",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": "{{authBaseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('token exists and is saved', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "  pm.environment.set('authToken', json.token);",
                  "});"
                ]
              }
            }
          ]
        },
